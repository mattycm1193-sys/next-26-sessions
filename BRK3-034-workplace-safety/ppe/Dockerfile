# Use a lightweight Python image
FROM python:3.11-slim

# Set the working directory
WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir fastapi uvicorn google-cloud-aiplatform>=1.40.0 pydantic

# Copy your python script (save your code as main.py)
COPY main.py .

# Expose the port FastAPI runs on
EXPOSE 8080

# Run the application
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]

